-- Đảm bảo cột ObjectID tồn tại trong bảng SY_User
IF NOT EXISTS (
    SELECT 1 FROM INFORMATION_SCHEMA.COLUMNS 
    WHERE TABLE_NAME = 'SY_User' AND COLUMN_NAME = 'ObjectID'
)
BEGIN
    ALTER TABLE [dbo].[SY_User] ADD [ObjectID] VARCHAR(50) NULL;
    PRINT '-> Đã bổ sung cột ObjectID vào bảng SY_User';
END

